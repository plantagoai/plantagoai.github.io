rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'feedmyinfo@gmail.com',
        'dagan.gilat@gmail.com'
      ];
    }

    match /contacts/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'interests', 'message', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 200
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.+@.+\\..+')
                    && request.resource.data.email.size() < 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() < 5000
                    && request.resource.data.interests is list
                    && request.resource.data.interests.size() <= 10;
      allow read, update, delete: if isAdmin();
    }

    match /subscribers/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'subscribedAt', 'unsubscribeToken'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.+@.+\\..+')
                    && request.resource.data.email.size() < 200
                    && request.resource.data.unsubscribeToken is string
                    && request.resource.data.unsubscribeToken.size() >= 16
                    && request.resource.data.unsubscribeToken.size() <= 128;
      allow read, update, delete: if isAdmin();
    }

    match /admin/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /projects/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
